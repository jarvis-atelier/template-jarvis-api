# Database connection (Postgres). Match this with docker-compose.yml for local dev.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/template_jarvis_api?schema=public"

# Server
PORT=3000
NODE_ENV=development

# CORS — comma-separated origins. In production, set to your real frontend URL(s).
# In dev, defaults to template-jarvis-web's Vite default (5173).
CORS_ORIGIN=http://localhost:5173
